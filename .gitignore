# =============================================================================
#  .gitignore — Rough Heston FNO Calibration project
# =============================================================================

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# ── Virtual environment ───────────────────────────────────────────────────────
.venv/
venv/
ENV/
env/

# ── Build / distribution ──────────────────────────────────────────────────────
build/
dist/
*.egg-info/
.eggs/

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
# NOTE: .ipynb files ARE tracked — override below
*.ipynb
!notebooks/*.ipynb

# ── IDE / Editor ─────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
Desktop.ini
*.bak

# ── Logs (keep folder, ignore content) ───────────────────────────────────────
logs/*
!logs/.gitkeep

# ── LaTeX compilation cache and aux files ────────────────────────────────────
tex/.latex_cache/*
!tex/.latex_cache/.gitkeep
tex/**/*.aux
tex/**/*.bbl
tex/**/*.bcf
tex/**/*.blg
tex/**/*.fdb_latexmk
tex/**/*.fls
tex/**/*.log
tex/**/*.nav
tex/**/*.out
tex/**/*.run.xml
tex/**/*.snm
tex/**/*.synctex.gz
tex/**/*.toc

# ── Compiled CUDA extensions (platform-specific) ─────────────────────────────
*.so
*.pyd

# ── Large datasets (reproduced by generate scripts) ──────────────────────────
data/*.npz
data/*.csv
data/market/**/*.parquet
data/market/**/*.csv
data/market/**/*.json

# ── Calibration result outputs (large, reproducible) ─────────────────────────
results/**/*.npz
results/**/*.npy
benchmarks/*.npy

# ── Model artifacts (legacy / archived weights) ───────────────────────────────
artifacts/legacy/
artifacts/reports/

# ── pytest cache ─────────────────────────────────────────────────────────────
.pytest_cache/
.coverage

# ── AI agent / tool configuration ────────────────────────────────────────────
mcp.json
.gemini/
.agents/
dev/

# ── AI-generated planning documents (not committed)
ROADMAP_P4_ONWARDS.md
*.ORIGINAL_REQUEST.md
*TIER*ORCHESTRATOR*.md

# ── Editor workspace files ────────────────────────────────────────────────────
*.code-workspace

# ── Environment files ────────────────────────────────────────────────────────
*.env
.env.*

# Generated images (output artifacts from fno_greeks.py etc.)
images/ai_generated/
