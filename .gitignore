# =============================================================================
#  .gitignore — Heston Deep Learning Calibration project
# =============================================================================

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# ── Virtual environment ───────────────────────────────────────────────────────
.venv/
venv/
ENV/
env/

# ── Build / distribution ──────────────────────────────────────────────────────
build/
dist/
*.egg-info/
.eggs/

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── IDE / Editor ─────────────────────────────────────────────────────────────
.vscode/settings.json
.idea/
*.swp
*.swo
*~

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# ── Logs  (keep folder via .gitkeep, ignore content) ─────────────────────────
logs/*
!logs/.gitkeep

# ── LaTeX compilation cache ──────────────────────────────────────────────────
tex/.latex_cache/*
!tex/.latex_cache/.gitkeep

# ── LaTeX junk that sometimes escapes the cache ──────────────────────────────
*.aux
*.bbl
*.bcf
*.blg
*.fdb_latexmk
*.fls
*.log
*.nav
*.out
*.run.xml
*.snm
*.synctex.gz
*.toc
# Do NOT ignore .tex source files
!*.tex

# ── Compiled PDFs (optional — keep if you want them in the repo) ─────────────
# Uncomment to exclude PDFs:
# *.pdf

# ── Trained model artefacts (large binary files) ─────────────────────────────
# Normally we ignore these if they are very large, but since our model weights 
# and scalers are tiny (< 500KB total) and required for the Streamlit app 
# deployment, we will track them in Git.
# artifacts/weights/*
# artifacts/scalers/*
# !artifacts/scalers/.gitkeep

# ── Misc ─────────────────────────────────────────────────────────────────────
*.env
.env.*
mcp.json
*.code-workspace

# Phase 7 Hardening
__pycache__/
*.pyc
*.pyo
.latex_cache/
.pytest_cache/
*.txt.gz
!data/samples/*.txt.gz

# ── AI agent / assistant generated files ─────────────────────────────────────
.antigravityignore
.gemini/
images/ai_generated/
speech_notes.md
dev/
research/2026_SOTA_update.md
research/option3_spec.md
research/thesis_defense_questions.md
research/deep_research_*.md

# ── Large datasets (reproduced by generate scripts) ──────────────────────────
data/*.npz
data/*.csv

# ── Compiled CUDA extensions (platform-specific) ─────────────────────────────
*.so
*.pyd

# ── Test / scratch files ─────────────────────────────────────────────────────
test_*.py
scripts/stress_test_*.py
