# =============================================================================
#  .gitignore — Rough Heston FNO Calibration project
# =============================================================================

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# ── Virtual environment ───────────────────────────────────────────────────────
.venv/
venv/
ENV/
env/

# ── Build / distribution ──────────────────────────────────────────────────────
build/
dist/
*.egg-info/
.eggs/

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
# NOTE: .ipynb files ARE tracked — override below
*.ipynb
!notebooks/*.ipynb

# ── IDE / Editor ─────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
Desktop.ini
*.bak

# ── Logs (keep folder, ignore content) ───────────────────────────────────────
logs/*
!logs/.gitkeep

# ── LaTeX compilation cache and aux files ────────────────────────────────────
tex/.latex_cache/*
!tex/.latex_cache/.gitkeep
tex/**/*.aux
tex/**/*.bbl
tex/**/*.bcf
tex/**/*.blg
tex/**/*.fdb_latexmk
tex/**/*.fls
tex/**/*.log
tex/**/*.nav
tex/**/*.out
tex/**/*.run.xml
tex/**/*.snm
tex/**/*.synctex.gz
tex/**/*.toc

# ── Compiled CUDA extensions (platform-specific) ─────────────────────────────
*.so
*.pyd

# ── Large datasets (reproduced by generate scripts) ──────────────────────────
data/*.npz
data/*.csv
data/cache/
data/market/**/*.parquet
data/market/**/*.csv
data/market/**/*.json

# ── Calibration result outputs (large, reproducible) ─────────────────────────
results/**/*.npz
results/**/*.npy
results/model_comparison_cache/
results/size_*.json
results/spx_calibration/
results/vix_term_structure/
benchmarks/*.npy

# ── Model artifacts (legacy / archived weights) ───────────────────────────────
artifacts/legacy/
artifacts/reports/
artifacts/models/fno_v2_best.pth

# ── pytest cache ─────────────────────────────────────────────────────────────
.pytest_cache/
.coverage

# ── AI agent / tool configuration ────────────────────────────────────────────
mcp.json
.gemini/
.agents/
dev/

# ── AI-generated planning documents (not committed)
ROADMAP_P4_ONWARDS.md
*.ORIGINAL_REQUEST.md
*TIER*ORCHESTRATOR*.md
app_frontend/AGENTS.md
app_frontend/CLAUDE.md
PROJECT.md
TEST_INFRA.md
TEST_READY.md

# ── Editor workspace files ────────────────────────────────────────────────────
*.code-workspace

# ── Environment files ────────────────────────────────────────────────────────
*.env
.env.*

# Generated images (output artifacts from fno_greeks.py etc.)
images/ai_generated/
P4_MODEL_ZOO_TASK.md

# ── Phase 7 temporary and research artifacts ─────────────────────────────────
ORIGINAL_REQUEST.md
OVERVIEW.md
P5_ROADMAP.md
P6_ROADMAP.md
ROADMAP.md
scratch/
articles/
research/
notebooks/generate_notebooks.py
notebooks/generate_p5_notebooks.py
notebooks/generate_p6_notebooks.py

