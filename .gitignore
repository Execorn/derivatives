# =============================================================================
#  .gitignore — Deep Rough Heston Calibration project
#  Last updated: 2026-06-18
# =============================================================================

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# ── Virtual environment ───────────────────────────────────────────────────────
.venv/
venv/
ENV/
env/

# ── Build / distribution ──────────────────────────────────────────────────────
build/
dist/
*.egg-info/
.eggs/

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── IDE / Editor ─────────────────────────────────────────────────────────────
.vscode/settings.json
.idea/
*.swp
*.swo
*~

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# ── Logs  (keep folder via .gitkeep, ignore content) ─────────────────────────
logs/*
!logs/.gitkeep

# ── LaTeX compilation cache ──────────────────────────────────────────────────
tex/.latex_cache/*
!tex/.latex_cache/.gitkeep

# ── LaTeX junk that sometimes escapes the cache ──────────────────────────────
*.aux
*.bbl
*.bcf
*.blg
*.fdb_latexmk
*.fls
*.log
*.nav
*.out
*.run.xml
*.snm
*.synctex.gz
*.toc
# Do NOT ignore .tex source files
!*.tex

# ── Compiled PDFs (optional — keep if you want them in the repo) ─────────────
# Uncomment to exclude PDFs:
# *.pdf

# ── Trained model artefacts (large binary files) ─────────────────────────────
# Normally we ignore these if they are very large, but since our model weights 
# and scalers are tiny (< 500KB total) and required for the Streamlit app 
# deployment, we will track them in Git.
# artifacts/weights/*
# artifacts/scalers/*
# !artifacts/scalers/.gitkeep

# ── Misc ─────────────────────────────────────────────────────────────────────
*.env
.env.*
mcp.json
*.code-workspace

# Phase 7 Hardening
__pycache__/
*.pyc
*.pyo
.latex_cache/
.pytest_cache/
*.txt.gz
!data/samples/*.txt.gz

# ── AI agent / assistant generated files ─────────────────────────────────────
.antigravityignore
.gemini/
dev/
test_*.py

# ── Large datasets (reproduced by generate scripts) ──────────────────────────
data/*.npz
data/*.csv

# ── Compiled CUDA extensions (platform-specific) ─────────────────────────────
*.so
*.pyd

# Project-internal AI context map — not for reviewers
CONTEXT.md

# ── AI-agent working directories ──────────────────────────────────────────────
.agents/
.gemini/

# ── LaTeX thesis compiled output (keep sources, ignore aux/pdf) ───────────────
tex/thesis/*.aux
tex/thesis/*.bbl
tex/thesis/*.bcf
tex/thesis/*.blg
tex/thesis/*.fdb_latexmk
tex/thesis/*.fls
tex/thesis/*.log
tex/thesis/*.out
tex/thesis/*.run.xml
tex/thesis/*.toc

# ── Speech notes (presenter notes, not thesis content) ───────────────────────
speech_notes.md

# ── Benchmark eval artefacts ─────────────────────────────────────────────────
benchmarks/*.npy

# ── AI-generated images (reproducible from scripts) ───────────────────────────
images/ai_generated/

# ── AI audit/analysis reports (not thesis content) ────────────────────────────
artifacts/reports/

# ── Tier 1 market data cache (downloaded on-demand, not committed) ────────────
data/market/**/*.parquet
data/market/**/*.csv
data/market/**/*.json

# ── Calibration result outputs (large, reproducible) ─────────────────────────
results/**/*.npz
results/**/*.npy

# ── Jupyter notebooks (track .ipynb files) ───────────────────────────────────
# Overriding earlier *.ipynb exclusion — we WANT notebooks in the repo
!notebooks/*.ipynb
.ipynb_checkpoints/

# ── Legacy weights (archived, too large for git) ─────────────────────────────
artifacts/legacy/

# ── Root pycache (escaped from src/) ─────────────────────────────────────────
/__pycache__/

# AI agent work directories
.agents/
*.ORIGINAL_REQUEST.md
*TIER*ORCHESTRATOR*.md

# Root-level ad-hoc scripts (not part of repo)
test_*.py
!tests/


# ── LaTeX build artifacts (not needed in git — only source + compiled PDF) ────
tex/**/*.aux
tex/**/*.log
tex/**/*.toc
tex/**/*.bbl
tex/**/*.bcf
tex/**/*.blg
tex/**/*.out
tex/**/*.run.xml
tex/**/*.nav
tex/**/*.snm
tex/**/*.fls
tex/**/*.fdb_latexmk
tex/.latex_cache/**/*
!tex/.latex_cache/.gitkeep

# ── Editor and tool config (machine-specific, not project files) ──────────────
*.code-workspace
mcp.json
.idea/
.vscode/

# ── Runtime log files ─────────────────────────────────────────────────────────
logs/*.log
logs/*.csv
!logs/.gitkeep

# ── Development scratch files ─────────────────────────────────────────────────
dev/
